# Microsoft Office temporary lock files
~$*

# Datasets (large public / local binary corpora)
# Anchor to repo-root only — on Windows, bare "DATA/" also matches **/data/
/DATA/
**/*.mat
**/*.gdf
**/*.bdf
**/*.edf

# Python
**/__pycache__/
**/*.py[cod]
**/.venv/
**/venv/
*.egg-info/
.pytest_cache/

# IDE
**/.idea/
**/.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Local outputs / plots (allow curated epoch .npy below)
**/out/
*.png
*.npy
!experiment_game/data/epochs/**/*.npy

# Nested-repo backup (LSL_connect_model had its own .git)
_git_backup_LSL_connect_model/
project_mi/

